{
  "expo": {
    "name": "Nightreel",
    "slug": "nightreel-mobile",
    "version": "1.0.0",
    "scheme": "nightreel",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-font"
    ],
    "updates": {
      "url": "https://u.expo.dev/b77197e7-0fd3-4ad4-a519-c7af150d26ed"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "package": "com.nightreel.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b77197e7-0fd3-4ad4-a519-c7af150d26ed"
      }
    }
  }
}
